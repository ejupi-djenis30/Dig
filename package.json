{
  "name": "dig-gopher-explorer",
  "version": "2.1.4",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "A small, inspectable Gopher protocol client and browser-based protocol explorer.",
  "bin": {
    "dig-gopher": "./bin/dig.mjs"
  },
  "files": [
    "bin",
    "src",
    "site/protocol.mjs",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "start": "node ./bin/dig.mjs --help",
    "test": "node --test",
    "test:e2e": "playwright test",
    "check:site": "node ./scripts/validate-site.mjs",
    "check:release": "node ./scripts/validate-release.mjs",
    "check": "npm test && npm run check:site && npm run check:release"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "remark-parse": "11.0.0",
    "unified": "11.0.5",
    "yaml": "2.9.0"
  }
}
